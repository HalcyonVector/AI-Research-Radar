DATABASE_URL=postgresql+psycopg://radar:radar@localhost:5432/radar_dev
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-run-python-c-import-secrets-print-secrets.token_hex-32
ENVIRONMENT=development

# AI: "local" (Ollama + sentence-transformers) or "cloud" (Gemini free tier)
AI_MODE=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_API_KEY=
