DATABASE_URL=postgresql+psycopg://radar:radar@localhost:5432/radar_dev
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-run-python-c-import-secrets-print-secrets.token_hex-32
ENVIRONMENT=development

# AI: "local" (Ollama) | "cloud" (Gemini) | "openai" (Groq/Cerebras/OpenRouter/Mistral)
AI_MODE=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible provider (set AI_MODE=openai). Groq default; free key at console.groq.com
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile
# Per-task routing: HEAVY = papers + Layer-3 intelligence (quality), LIGHT = model/repo cards (volume).
OPENAI_MODEL_HEAVY=llama-3.3-70b-versatile
OPENAI_MODEL_LIGHT=llama-3.1-8b-instant

# Embeddings: "local" (384d) or "gemini" (768d). Keep EMBEDDING_DIM in sync before migrating.
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=384

# Optional free tokens. GITHUB_TOKEN strongly recommended: raises the GitHub API
# limit from 60/hr to 5000/hr so README fetching for repo summaries isn't throttled.
HF_API_TOKEN=
GITHUB_TOKEN=

# Solo/free hosting: run Celery tasks in-process synchronously
CELERY_EAGER=false
CACHE_ENABLED=true
